{
    "name": "atlas",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "check": "turbo run check",
        "test": "turbo run test",
        "format": "biome format --write .",
        "check-biome": "biome check --write .",
        "check-types": "turbo run check-types"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "turbo": "^2.10.4",
        "typescript": "7.0.2"
    },
    "engines": {
        "node": ">=18"
    },
    "devEngines": {
        "packageManager": {
            "name": "bun",
            "version": "1.3.14"
        }
    },
    "workspaces": [
        "apps/*",
        "packages/*",
        "mobile"
    ]
}
