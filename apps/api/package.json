{
    "name": "api",
    "version": "1.0.50",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev": "bun run --watch src/index.ts",
        "format": "biome format --write .",
        "lint": "biome lint",
        "check": "biome check",
        "check-types": "tsc --noEmit",
        "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile dist/server src/index.ts",
        "build:linux-x64": "bun build --compile --target=bun-linux-x64 --minify-whitespace --minify-syntax --target bun --outfile dist/server-linux-x64 src/index.ts",
        "build:linux-x64-baseline": "bun build --compile --target=bun-linux-x64-baseline --minify-whitespace --minify-syntax --target bun --outfile dist/server-linux-x64-baseline src/index.ts",
        "build:linux-x64-modern": "bun build --compile --target=bun-linux-x64-modern --minify-whitespace --minify-syntax --target bun --outfile dist/server-linux-x64-modern src/index.ts",
        "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 --minify-whitespace --minify-syntax --target bun --outfile dist/server-linux-arm64 src/index.ts",
        "build:windows-x64": "bun build --compile --target=bun-windows-x64 --minify-whitespace --minify-syntax --target bun --outfile dist/server-windows-x64 src/index.ts",
        "build:windows-x64-baseline": "bun build --compile --target=bun-windows-x64-baseline --minify-whitespace --minify-syntax --target bun --outfile dist/server-windows-x64-baseline src/index.ts",
        "build:windows-x64-modern": "bun build --compile --target=bun-windows-x64-modern --minify-whitespace --minify-syntax --target bun --outfile dist/server-windows-x64-modern src/index.ts",
        "build:windows-arm64": "bun build --compile --target=bun-windows-arm64 --minify-whitespace --minify-syntax --target bun --outfile dist/server-windows-arm64 src/index.ts",
        "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --minify-whitespace --minify-syntax --target bun --outfile dist/server-darwin-arm64 src/index.ts",
        "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 --minify-whitespace --minify-syntax --target bun --outfile dist/server-darwin-x64 src/index.ts",
        "build:all": "bun run build:linux-x64 && bun run build:linux-x64-baseline && bun run build:linux-x64-modern && bun run build:linux-arm64 && bun run build:windows-x64 && bun run build:windows-x64-baseline && bun run build:windows-x64-modern && bun run build:windows-arm64 && bun run build:darwin-arm64 && bun run build:darwin-x64"
    },
    "dependencies": {
        "elysia": "latest"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@repo/biome": "workspace:*",
        "@biomejs/biome": "2.5.3",
        "bun-types": "latest"
    },
    "module": "src/index.js"
}
