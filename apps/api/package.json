{
    "name": "api",
    "version": "1.0.50",
    "scripts": {
        "test": "bun test --pass-with-no-tests",
        "dev": "bun run --watch src/index.ts",
        "dev-sec": "infisical run -- bun run dev",
        "format": "biome format --write .",
        "lint": "biome lint",
        "check": "biome check",
        "check-types": "tsc --noEmit",
        "build": "bun build --compile --minify --target bun --outfile dist/server src/index.ts",
        "build:linux-x64": "bun build --compile --target=bun-linux-x64 --minify --outfile dist/server-linux-x64 src/index.ts",
        "build:linux-x64-baseline": "bun build --compile --target=bun-linux-x64-baseline --minify --outfile dist/server-linux-x64-baseline src/index.ts",
        "build:linux-x64-modern": "bun build --compile --target=bun-linux-x64-modern --minify --outfile dist/server-linux-x64-modern src/index.ts",
        "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 --minify --outfile dist/server-linux-arm64 src/index.ts",
        "build:windows-x64": "bun build --compile --target=bun-windows-x64 --minify --outfile dist/server-windows-x64 src/index.ts",
        "build:windows-x64-baseline": "bun build --compile --target=bun-windows-x64-baseline --minify --outfile dist/server-windows-x64-baseline src/index.ts",
        "build:windows-x64-modern": "bun build --compile --target=bun-windows-x64-modern --minify --outfile dist/server-windows-x64-modern src/index.ts",
        "build:windows-arm64": "bun build --compile --target=bun-windows-arm64 --minify --outfile dist/server-windows-arm64 src/index.ts",
        "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --minify --outfile dist/server-darwin-arm64 src/index.ts",
        "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 --minify --outfile dist/server-darwin-x64 src/index.ts",
        "build:all": "bun run build:linux-x64 && bun run build:linux-x64-baseline && bun run build:linux-x64-modern && bun run build:linux-arm64 && bun run build:windows-x64 && bun run build:windows-x64-baseline && bun run build:windows-x64-modern && bun run build:windows-arm64 && bun run build:darwin-arm64 && bun run build:darwin-x64"
    },
    "dependencies": {
        "@elysia/openapi": "^1.4.15",
        "@sinclair/typebox": "0.34.52",
        "@t3-oss/env-core": "^0.13.11",
        "better-auth": "^1.6.23",
        "drizzle-orm": "^1.0.0-rc.4",
        "elysia": "latest",
        "pg": "^8.22.0",
        "valibot": "^1.4.2"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "@repo/biome": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@types/pg": "^8.20.0",
        "bun-types": "^1.3.14",
        "drizzle-kit": "^1.0.0-rc.4",
        "typescript": "7.0.2"
    },
    "module": "src/index.js"
}
